{
  "name": "@denny-il/drizzle-pg-utils",
  "description": "Set of utilities for Drizzle ORM and PostgreSQL",
  "homepage": "https://github.com/denny-il/drizzle-pg-utils",
  "keywords": [
    "drizzle",
    "drizzle-orm",
    "postgres",
    "pg",
    "utils",
    "json",
    "temporal"
  ],
  "author": {
    "name": "Denny Il",
    "email": "ilchishin.denis@gmail.com",
    "url": "https://github.com/denny-il"
  },
  "repository": {
    "url": "https://github.com/denny-il/drizzle-pg-utils"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "module-sync": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./json": {
      "import": "./src/json/index.ts",
      "module-sync": "./src/json/index.ts",
      "types": "./src/json/index.ts"
    },
    "./json/*": {
      "import": "./src/json/operations/*.ts",
      "module-sync": "./src/json/operations/*.ts",
      "types": "./src/json/operations/*.ts"
    },
    "./temporal": {
      "import": "./src/temporal/global.ts",
      "module-sync": "./src/temporal/global.ts",
      "types": "./src/temporal/global.ts"
    },
    "./temporal/polyfill": {
      "import": "./src/temporal/polyfill.ts",
      "module-sync": "./src/temporal/polyfill.ts",
      "types": "./src/temporal/polyfill.ts"
    },
    "./temporal/*": {
      "import": "./src/temporal/polyfill/*.ts",
      "module-sync": "./src/temporal/polyfill/*.ts",
      "types": "./src/temporal/polyfill/*.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "module-sync": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./json": {
        "import": "./dist/json/index.js",
        "module-sync": "./dist/json/index.js",
        "types": "./dist/json/index.d.ts"
      },
      "./json/*": {
        "import": "./dist/json/operations/*.js",
        "module-sync": "./dist/json/operations/*.js",
        "types": "./dist/json/operations/*.d.ts"
      },
      "./temporal": {
        "import": "./dist/temporal/global.js",
        "module-sync": "./dist/temporal/global.js",
        "types": "./dist/temporal/global.d.ts"
      },
      "./temporal/polyfill": {
        "import": "./dist/temporal/polyfill.js",
        "module-sync": "./dist/temporal/polyfill.js",
        "types": "./dist/temporal/polyfill.d.ts"
      },
      "./temporal/*": {
        "import": "./dist/temporal/polyfill/*.js",
        "module-sync": "./dist/temporal/polyfill/*.js",
        "types": "./dist/temporal/polyfill/*.d.ts"
      }
    }
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsgo -p tsconfig.build.json",
    "check:type": "tsgo --noEmit",
    "check:lint": "biome lint .",
    "check:fmt": "biome format .",
    "check": "pnpm run check:fmt && pnpm run check:lint && pnpm run check:type",
    "fmt": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@electric-sql/pglite": "0.3.15",
    "@types/node": "20",
    "@typescript/native-preview": "7.0.0-dev.20260204.1",
    "drizzle-orm": "1.0.0-beta.14-a36c63d",
    "temporal-polyfill": "^0.3.0",
    "temporal-spec": "^0.3.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "drizzle-orm": "1.0.0-beta.14-a36c63d",
    "temporal-polyfill": "^0.3.0",
    "temporal-spec": "^0.3.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "temporal-polyfill": {
      "optional": true
    },
    "temporal-spec": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264"
}
